<!-- ═══ JAVASCRIPT ═══ -->
<script>
/* ─────────────────────────────────────
   अपने Audio File IDs यहाँ डालें
   कैसे निकालें:
   1. Drive में audio file पर right-click
   2. Share → Copy link
   3. Link से ID निकालें:
      https://drive.google.com/file/d/ [ID] /view
   4. नीचे tracks array में add करें
───────────────────────────────────── */
const tracks = [
  // उदाहरण — इन्हें अपने real IDs से replace करें:
  // { name: "प्रवचन १ – निष्पक्ष समझ",       id: "1aBcDeFgHiJkL..." },
  // { name: "प्रवचन २ – खुद का साक्षात्कार",  id: "2XyZaBcDeFgH..." },
];

/* ─── Player Logic ─── */
const player  = document.getElementById('mainPlayer');
const tList   = document.getElementById('trackList');
const playBtn = document.getElementById('playBtn');
const loopBtn = document.getElementById('loopBtn');
const nowP    = document.getElementById('nowPlaying');
let cur = 0, looping = true;

function buildList() {
  if (!tracks.length) {
    tList.innerHTML = `
      <li style="padding:18px 26px;color:var(--muted);font-size:.88rem;line-height:2;">
        अभी tracks नहीं हैं। ऊपर JavaScript में File IDs add करें।<br>
        तब तक — नीचे Drive Folder buttons से सुनें।
      </li>`;
    nowP.innerHTML = 'Drive Folder से सुनें ↓';
    return;
  }
  tracks.forEach((t, i) => {
    const li = document.createElement('li');
    li.className = 'track-item' + (i === 0 ? ' active' : '');
    li.innerHTML = `
      <span class="t-num">${String(i+1).padStart(2,'0')}</span>
      <span class="t-ic">${i===0?'▶':'○'}</span>
      <span class="t-name">${t.name}</span>`;
    li.onclick = () => load(i, true);
    tList.appendChild(li);
  });
}

function load(i, play = false) {
  if (!tracks.length) return;
  cur = i;
  player.src = `https://docs.google.com/uc?export=open&id=${tracks[i].id}`;
  if (play) player.play().catch(() => {});
  nowP.innerHTML = `चल रहा है: <em>${tracks[i].name}</em>`;
  document.querySelectorAll('.track-item').forEach((el, j) => {
    el.classList.toggle('active', j === i);
    el.querySelector('.t-ic').textContent = j === i ? '▶' : '○';
  });
}

function togglePlay() {
  if (!tracks.length) return;
  player.paused ? player.play() : player.pause();
}
function nextTrack() { if (tracks.length) load((cur+1) % tracks.length, true); }
function prevTrack() { if (tracks.length) load((cur-1+tracks.length) % tracks.length, true); }
function toggleLoop() {
  looping = !looping;
  loopBtn.classList.toggle('on', looping);
}

player.addEventListener('play',  () => { playBtn.textContent = '⏸'; });
player.addEventListener('pause', () => { playBtn.textContent = '▶'; });
player.addEventListener('ended', () => { if (looping) nextTrack(); });

window.addEventListener('load', () => {
  buildList();
  if (tracks.length) load(0, true);
});

/* ─── Mobile Menu ─── */
const ham = document.getElementById('hamburger');
const mob = document.getElementById('mobileMenu');
ham.addEventListener('click', () => mob.classList.toggle('open'));
function closeMob() { mob.classList.remove('open'); }

/* ─── Active Nav on Scroll ─── */
const sections = document.querySelectorAll('section[id], div[id="home"]');
const navLinks = document.querySelectorAll('.nav-menu a, .mobile-menu a');
window.addEventListener('scroll', () => {
  let cur = '';
  sections.forEach(s => {
    if (window.scrollY >= s.offsetTop - 80) cur = s.id;
  });
  navLinks.forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + cur);
  });
});

/* ─── Scroll Fade-In ─── */
const obs = new IntersectionObserver(es => {
  es.forEach(e => { if (e.isIntersecting) e.target.classList.add('vis'); });
}, { threshold: 0.1 });
document.querySelectorAll('.fu').forEach(el => obs.observe(el));
</script>
